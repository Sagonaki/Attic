####################################################################
# Attic SPA — Node build → nginx serve.                             #
# Build context: the repo root (docker compose uses `context: .`).  #
####################################################################

# ---- build ----
FROM node:22-alpine AS build
WORKDIR /src

COPY src/Attic.Web/package.json src/Attic.Web/package-lock.json src/Attic.Web/.npmrc ./
RUN --mount=type=cache,target=/root/.npm npm ci

COPY src/Attic.Web/ ./
RUN npm run build

# ---- runtime ----
FROM nginx:1.27-alpine AS runtime

# Replace the default server block with one that serves the SPA and
# reverse-proxies /api + /hub (WebSocket-aware) to the api service.
RUN rm /etc/nginx/conf.d/default.conf
COPY deploy/nginx.conf       /etc/nginx/conf.d/default.conf
COPY --from=build /src/dist  /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=10s --timeout=3s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost/ > /dev/null || exit 1
